{
  "name": "projectcare",
  "private": true,
  "version": "0.1.0",
  "description": "ProjectCare monorepo (web + api + shared)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace @projectcare/web",
    "dev:api": "npm run dev --workspace @projectcare/api",
    "dev": "concurrently -n WEB,API -c green,blue --kill-others \"npm run dev:web\" \"npm run dev:api\""
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}